在 create 函数中添加以下实现（在现有的 addNode 之前）：

```typescript
// 从服务器加载主题
loadTopicsFromServer: async () => {
  try {
    const response = await fetch('/api/topics');
    if (!response.ok) return;
    
    const { data } = await response.json();
    const topics: Record<string, Topic> = {};
    data.forEach((topic: Topic) => {
      topics[topic.id] = topic;
    });
    
    set({ topics });
  } catch (error) {
    console.error('加载主题失败:', error);
  }
},

// 从服务器加载节点
loadNodesFromServer: async () => {
  try {
    const topicId = get().currentTopicId;
    const url = topicId ? `/api/nodes?topicId=${topicId}` : '/api/nodes';
    
    const response = await fetch(url);
    if (!response.ok) return;
    
    const { data } = await response.json();
    
    const nodes: Record<string, KnowledgeNode> = {};
    const rootNodeIds: string[] = [];
    
    data.forEach((node: KnowledgeNode) => {
      nodes[node.id] = node;
      if (!node.parentId) {
        rootNodeIds.push(node.id);
      }
    });
    
    set({ nodes, rootNodeIds });
  } catch (error) {
    console.error('加载节点失败:', error);
  }
},

// 同步节点到服务器
syncNodeToServer: async (node: KnowledgeNode) => {
  try {
    const response = await fetch('/api/nodes', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(node),
    });
    
    if (!response.ok) {
      console.error('同步节点失败');
    }
  } catch (error) {
    console.error('同步节点失败:', error);
  }
},
```

修改现有的 addNode 方法，添加服务器同步：

```typescript
addNode: (node: KnowledgeNode) => {
  set((state) => {
    const newNodes = { ...state.nodes, [node.id]: node };
    const newRootNodeIds = node.parentId
      ? state.rootNodeIds
      : [...state.rootNodeIds, node.id];

    // 异步同步到服务器（不阻塞 UI）
    get().syncNodeToServer(node);

    return {
      nodes: newNodes,
      rootNodeIds: newRootNodeIds,
      selectedNodeId: node.id,
      expandedNodeIds: node.parentId
        ? [...state.expandedNodeIds, node.parentId]
        : state.expandedNodeIds,
    };
  });
},
```

